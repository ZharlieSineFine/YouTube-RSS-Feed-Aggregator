__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Secrets and local environment
.env
.env.local

# Local SQLite and app data directory
data/
*.db

# HTTP / ingest cache (large, machine-local)
.cache/

