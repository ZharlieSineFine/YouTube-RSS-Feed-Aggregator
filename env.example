# Copy to ".env" and fill in secrets. See docker/README.md for PostgreSQL via Docker.

# --- Database (pick one style) ---
# SQLite (default if nothing below is set):
# DATABASE_URL=sqlite:///data/aggregator.db

# PostgreSQL (SQLAlchemy + psycopg3 — generic URL is normalized automatically):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_news_aggregator
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ai_news_aggregator

# Or discrete vars (used when DATABASE_URL is unset and POSTGRES_HOST is set):
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=ai_news_aggregator

# --- Agent LLM (default: Ollama — no cloud API key) ---
# AGENT_LLM_BACKEND=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen3:14b
# Optional: OpenAI API instead of Ollama
# AGENT_LLM_BACKEND=openai
# OPENAI_API_KEY=
# Per-article summaries: en -> Article.summary, zh-cn -> Article.summary_zh
# AGENT_SUMMARY_LANGUAGES=en,zh-cn
# Legacy single language if AGENT_SUMMARY_LANGUAGES unset:
# AGENT_SUMMARY_LANGUAGE=zh-cn

# --- Digest email ---
# For a daily schedule, limit digest articles (UTC). With DIGEST_SINCE_HOURS=24 the cutoff also
# floors to start of yesterday UTC so midnight date-stamps are included (see DIGEST_SINCE_STRICT_ROLLING).
# DIGEST_SINCE_HOURS=24
# DIGEST_SINCE_STRICT_ROLLING=1
# DIGEST_SMTP_HOST=
# DIGEST_SMTP_PORT=587
# DIGEST_SMTP_USER=
# DIGEST_SMTP_PASSWORD=
# DIGEST_EMAIL_FROM=
# Split recipients (English vs Chinese body). When set, DIGEST_EMAIL_TO is not used for sending.
# DIGEST_EMAIL_TO_EN=reader1@example.com,reader2@example.com,reader3@example.com
# DIGEST_EMAIL_TO_ZH=reader4@example.com,reader5@example.com
# Legacy single digest (uses Article.summary only):
# DIGEST_EMAIL_TO=you@example.com,other@example.com
# Optional chrome when using legacy single digest: zh-cn | zh-hans | chinese
# DIGEST_UI_LANGUAGE=zh-cn

# --- Windows Task Scheduler (optional) ---
# AGGREGATOR_AGENT_LIMIT=50
